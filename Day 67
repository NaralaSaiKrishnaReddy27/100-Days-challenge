#include <stdio.h>
#include <stdlib.h>

struct Node {
    int dest;
    struct Node* next;
};

// Global stack and its pointer
int* stack;
int top = -1;

void push(int val) {
    stack[++top] = val;
}

// Helper to add directed edge
void addEdge(struct Node* adj[], int u, int v) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->dest = v;
    newNode->next = adj[u];
    adj[u] = newNode;
}

// DFS function for Topological Sort
void topoSortUtil(int u, struct Node* adj[], int visited[]) {
    visited[u] = 1;

    struct Node* temp = adj[u];
    while (temp != NULL) {
        int v = temp->dest;
        if (!visited[v]) {
            topoSortUtil(v, adj, visited);
        }
        temp = temp->next;
    }

    // Once all neighbors are visited, push current node to stack
    push(u);
}

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    struct Node** adj = (struct Node**)malloc(n * sizeof(struct Node*));
    for (int i = 0; i < n; i++) adj[i] = NULL;

    for (int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        addEdge(adj, u, v);
    }

    int* visited = (int*)calloc(n, sizeof(int));
    stack = (int*)malloc(n * sizeof(int));

    // Call DFS for all unvisited components
    for (int i = 0; i < n; i++) {
        if (!visited[i]) {
            topoSortUtil(i, adj, visited);
        }
    }

    // Print stack contents (LIFO)
    printf("Topological Order: ");
    while (top >= 0) {
        printf("%d ", stack[top--]);
    }
    printf("\n");

    return 0;
}
