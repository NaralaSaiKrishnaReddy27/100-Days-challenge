#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// Comparator function for qsort to sort strings alphabetically
int compareStrings(const void* a, const void* b) {
    return strcmp(*(const char**)a, *(const char**)b);
}

void findWinner(int n, char** votes) {
    if (n == 0) return;

    // 1. Sort the names alphabetically
    qsort(votes, n, sizeof(char*), compareStrings);

    char* winner = votes[0];
    int maxVotes = 0;
    
    int currentVotes = 1;
    char* currentCandidate = votes[0];

    for (int i = 1; i <= n; i++) {
        // If it's the same name as the previous one, increment count
        if (i < n && strcmp(votes[i], currentCandidate) == 0) {
            currentVotes++;
        } else {
            // New candidate or end of list: check if they won
            if (currentVotes > maxVotes) {
                maxVotes = currentVotes;
                winner = currentCandidate;
            }
            // Tie-break: Since we sorted alphabetically, the first candidate 
            // encountered with maxVotes is already the lexicographical winner.
            
            if (i < n) {
                currentCandidate = votes[i];
                currentVotes = 1;
            }
        }
    }

    printf("%s %d\n", winner, maxVotes);
}

int main() {
    int n;
    if (scanf("%d", &n) != 1) return 0;

    // Dynamically allocate array for string pointers
    char** votes = (char**)malloc(n * sizeof(char*));
    for (int i = 0; i < n; i++) {
        votes[i] = (char*)malloc(101 * sizeof(char)); // Max name length 100
        scanf("%s", votes[i]);
    }

    findWinner(n, votes);

    // Cleanup
    for (int i = 0; i < n; i++) free(votes[i]);
    free(votes);

    return 0;
}
