#include <stdio.h>
#include <stdlib.h>

struct Node {
    int dest;
    struct Node* next;
};

// Simple Queue Implementation
struct Queue {
    int *items;
    int front, rear, count, capacity;
};

struct Queue* createQueue(int n) {
    struct Queue* q = (struct Queue*)malloc(sizeof(struct Queue));
    q->capacity = n;
    q->items = (int*)malloc(n * sizeof(int));
    q->front = 0;
    q->rear = -1;
    q->count = 0;
    return q;
}

void enqueue(struct Queue* q, int val) {
    q->items[++q->rear] = val;
    q->count++;
}

int dequeue(struct Queue* q) {
    q->count--;
    return q->items[q->front++];
}

// Add Directed Edge
void addEdge(struct Node* adj[], int u, int v, int inDegree[]) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->dest = v;
    newNode->next = adj[u];
    adj[u] = newNode;
    inDegree[v]++; // Increment in-degree of the destination node
}

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    struct Node** adj = (struct Node**)malloc(n * sizeof(struct Node*));
    int* inDegree = (int*)calloc(n, sizeof(int));
    for (int i = 0; i < n; i++) adj[i] = NULL;

    for (int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        addEdge(adj, u, v, inDegree);
    }

    struct Queue* q = createQueue(n);
    for (int i = 0; i < n; i++) {
        if (inDegree[i] == 0) enqueue(q, i);
    }

    int* topoOrder = (int*)malloc(n * sizeof(int));
    int index = 0;

    while (q->count > 0) {
        int u = dequeue(q);
        topoOrder[index++] = u;

        struct Node* temp = adj[u];
        while (temp != NULL) {
            int v = temp->dest;
            inDegree[v]--; // "Remove" the edge
            if (inDegree[v] == 0) {
                enqueue(q, v);
            }
            temp = temp->next;
        }
    }

    if (index != n) {
        printf("Graph contains a cycle! Topological sort not possible.\n");
    } else {
        printf("Topological Order: ");
        for (int i = 0; i < n; i++) printf("%d ", topoOrder[i]);
        printf("\n");
    }

    return 0;
}
