#include <stdio.h>

int main() {
    int n, k;
    int comparisons = 0;
    int foundIndex = -1;

    // Read array size
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];

    // Read array elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Read the key to search for
    scanf("%d", &k);

    // Perform Linear Search
    for (int i = 0; i < n; i++) {
        comparisons++; // Increment every time we perform a check
        if (arr[i] == k) {
            foundIndex = i;
            break; // Exit loop as soon as key is found
        }
    }

    // Output results
    if (foundIndex != -1) {
        printf("Found at index %d\n", foundIndex);
    } else {
        printf("Not Found\n");
    }
    printf("Comparisons = %d\n", comparisons);

    return 0;
}
