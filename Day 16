#include <stdio.h>

int main() {
    int n;

    // Read the size of the array
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];
    int visited[n]; // Array to keep track of elements already counted

    // Read array elements and initialize visited array
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        visited[i] = 0; // 0 means not visited
    }

    int first = 1; // Helper for space-separated formatting

    for (int i = 0; i < n; i++) {
        // Skip this element if it has already been counted
        if (visited[i] == 1) {
            continue;
        }

        int count = 1;
        // Search for duplicates in the remaining part of the array
        for (int j = i + 1; j < n; j++) {
            if (arr[i] == arr[j]) {
                count++;
                visited[j] = 1; // Mark as visited so we don't count it again
            }
        }

        // Print the result in element:count format
        printf("%s%d:%d", first ? "" : " ", arr[i], count);
        first = 0;
    }
    printf("\n");

    return 0;
}
