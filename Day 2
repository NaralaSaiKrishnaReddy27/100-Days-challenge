#include <stdio.h>

int main() {
    int n, pos;

    // Read initial size
    if (scanf("%d", &n) != 1) return 0;

    int arr[n];

    // Read array elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Read the 1-based position to delete
    scanf("%d", &pos);

    // If the position is valid, perform the deletion
    if (pos < 1 || pos > n) {
        // Handle invalid position if necessary, though typical 
        // competitive programming assumes valid input.
        return 0;
    }

    // Shift elements to the left starting from the position to be deleted
    // The loop starts at the index to be deleted (pos-1)
    for (int i = pos - 1; i < n - 1; i++) {
        arr[i] = arr[i + 1];
    }

    // Print the updated array (now with n-1 elements)
    for (int i = 0; i < n - 1; i++) {
        printf("%d%s", arr[i], (i == n - 2) ? "" : " ");
    }
    printf("\n");

    return 0;
}
