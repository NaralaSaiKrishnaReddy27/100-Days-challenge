#include <stdio.h>
#include <stdlib.h>

#define TABLE_SIZE 100003 // Large prime for hashing

typedef struct Node {
    long long sum;
    int index;
    struct Node* next;
} Node;

// Basic Hash Table for storing {PrefixSum: FirstIndex}
Node* hashTable[TABLE_SIZE];

int hash(long long sum) {
    int h = sum % TABLE_SIZE;
    return (h < 0) ? h + TABLE_SIZE : h;
}

void insert(long long sum, int index) {
    int h = hash(sum);
    Node* newNode = (Node*)malloc(sizeof(Node));
    newNode->sum = sum;
    newNode->index = index;
    newNode->next = hashTable[h];
    hashTable[h] = newNode;
}

int find(long long sum) {
    int h = hash(sum);
    Node* temp = hashTable[h];
    while (temp) {
        if (temp->sum == sum) return temp->index;
        temp = temp->next;
    }
    return -2; // Not found
}

int maxLenZeroSum(int arr[], int n) {
    long long currSum = 0;
    int maxLen = 0;

    for (int i = 0; i < n; i++) {
        currSum += arr[i];

        if (currSum == 0) {
            maxLen = i + 1;
        } else {
            int prevIndex = find(currSum);
            if (prevIndex != -2) {
                if (i - prevIndex > maxLen) {
                    maxLen = i - prevIndex;
                }
            } else {
                insert(currSum, i);
            }
        }
    }
    return maxLen;
}

int main() {
    int arr[] = {15, -2, 2, -8, 1, 7, 10, 23};
    int n = sizeof(arr) / sizeof(arr[0]);

    printf("%d\n", maxLenZeroSum(arr, n));

    return 0;
}
