#include <stdio.h>
#include <stdlib.h>

// Define Binary Tree Node
struct Node {
    int data;
    struct Node *left, *right;
};

// Helper to create a new tree node
struct Node* newNode(int val) {
    if (val == -1) return NULL;
    struct Node* node = (struct Node*)malloc(sizeof(struct Node));
    node->data = val;
    node->left = node->right = NULL;
    return node;
}

// Function to perform Level Order Traversal
void levelOrderTraversal(struct Node* root, int n) {
    if (root == NULL) return;

    // Use an array-based queue for simplicity
    struct Node** queue = (struct Node**)malloc(n * sizeof(struct Node*));
    int front = 0, rear = 0;

    queue[rear++] = root;

    while (front < rear) {
        struct Node* current = queue[front++];
        
        // Print current node data
        printf("%d ", current->data);

        // Enqueue left child
        if (current->left != NULL) {
            queue[rear++] = current->left;
        }

        // Enqueue right child
        if (current->right != NULL) {
            queue[rear++] = current->right;
        }
    }
    printf("\n");
    free(queue);
}

int main() {
    int n;
    if (scanf("%d", &n) != 1 || n <= 0) return 0;

    int *arr = (int*)malloc(n * sizeof(int));
    for (int i = 0; i < n; i++) scanf("%d", &arr[i]);

    // Build the tree using level-order logic
    struct Node** constructionQueue = (struct Node**)malloc(n * sizeof(struct Node*));
    int cFront = 0, cRear = 0;

    struct Node* root = newNode(arr[0]);
    if (root) constructionQueue[cRear++] = root;

    int i = 1;
    while (i < n && cFront < cRear) {
        struct Node* parent = constructionQueue[cFront++];
        
        // Assign left
        parent->left = newNode(arr[i++]);
        if (parent->left) constructionQueue[cRear++] = parent->left;
        
        // Assign right
        if (i < n) {
            parent->right = newNode(arr[i++]);
            if (parent->right) constructionQueue[cRear++] = parent->right;
        }
    }

    // Execute Traversal
    levelOrderTraversal(root, n);

    return 0;
}
