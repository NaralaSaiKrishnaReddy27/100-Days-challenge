#include <stdio.h>
#include <stdlib.h>

struct Node {
    int dest;
    struct Node* next;
};

// Helper to add directed edge
void addEdge(struct Node* adj[], int u, int v) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->dest = v;
    newNode->next = adj[u];
    adj[u] = newNode;
}

// DFS function to detect cycle in directed graph
int isCyclicUtil(int u, struct Node* adj[], int visited[], int recStack[]) {
    if (!visited[u]) {
        // Mark the current node as visited and part of recursion stack
        visited[u] = 1;
        recStack[u] = 1;

        struct Node* temp = adj[u];
        while (temp != NULL) {
            int v = temp->dest;
            
            // If not visited, recurse
            if (!visited[v] && isCyclicUtil(v, adj, visited, recStack))
                return 1;
            // If already in recursion stack, cycle found
            else if (recStack[v])
                return 1;
                
            temp = temp->next;
        }
    }
    // Remove the node from recursion stack before backtracking
    recStack[u] = 0;
    return 0;
}

int main() {
    int n, m;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    struct Node** adj = (struct Node**)malloc(n * sizeof(struct Node*));
    for (int i = 0; i < n; i++) adj[i] = NULL;

    for (int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        addEdge(adj, u, v); // Directed: u -> v
    }

    int* visited = (int*)calloc(n, sizeof(int));
    int* recStack = (int*)calloc(n, sizeof(int));
    int hasCycle = 0;

    for (int i = 0; i < n; i++) {
        if (isCyclicUtil(i, adj, visited, recStack)) {
            hasCycle = 1;
            break;
        }
    }

    if (hasCycle) printf("YES\n");
    else printf("NO\n");

    return 0;
}
