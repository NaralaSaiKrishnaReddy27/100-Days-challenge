#include <stdio.h>

int main() {
    int m, n;

    // Read rows (m) and columns (n)
    if (scanf("%d %d", &m, &n) != 2) return 0;

    int mat[m][n];

    // Read the matrix elements
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &mat[i][j]);
        }
    }

    // Step 1: A symmetric matrix MUST be square
    if (m != n) {
        printf("Not a Symmetric Matrix\n");
        return 0;
    }

    int isSymmetric = 1; // Flag assuming it is symmetric

    // Step 2: Check if mat[i][j] == mat[j][i]
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            if (mat[i][j] != mat[j][i]) {
                isSymmetric = 0; // Mismatch found
                break;
            }
        }
        if (!isSymmetric) break;
    }

    // Output result
    if (isSymmetric) {
        printf("Symmetric Matrix\n");
    } else {
        printf("Not a Symmetric Matrix\n");
    }

    return 0;
}
