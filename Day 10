#include <stdio.h>
#include <string.h>

int main() {
    char str[100];

    // Read input string
    if (scanf("%s", str) != 1) return 0;

    int left = 0;
    int right = strlen(str) - 1;
    int isPalindrome = 1; // Assume it is a palindrome (1 for true)

    // Move pointers towards each other
    while (left < right) {
        if (str[left] != str[right]) {
            isPalindrome = 0; // Found a mismatch
            break;
        }
        left++;
        right--;
    }

    // Output result
    if (isPalindrome) {
        printf("YES\n");
    } else {
        printf("NO\n");
    }

    return 0;
}
