#include <stdio.h>

int main() {
    int m, n;
    long long sum = 0;

    // Read dimensions m (rows) and n (columns)
    if (scanf("%d %d", &m, &n) != 2) return 0;

    int mat[m][n];

    // Read the matrix elements
    for (int i = 0; i < m; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &mat[i][j]);
        }
    }

    // The primary diagonal exists only where row index == column index
    // The number of such elements is the minimum of m and n
    int limit = (m < n) ? m : n;

    for (int i = 0; i < limit; i++) {
        sum += mat[i][i];
    }

    // Print the final sum
    printf("%lld\n", sum);

    return 0;
}
