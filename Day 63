#include <stdio.h>
#include <stdlib.h>

// Node for Adjacency List
struct Node {
    int dest;
    struct Node* next;
};

// Global or passed visited array
int* visited;

// DFS Recursive Function
void DFS(struct Node* adj[], int u) {
    // 1. Mark current node as visited
    visited[u] = 1;
    
    // 2. Print current node
    printf("%d ", u);

    // 3. Recur for all adjacent vertices
    struct Node* temp = adj[u];
    while (temp != NULL) {
        int v = temp->dest;
        if (!visited[v]) {
            DFS(adj, v);
        }
        temp = temp->next;
    }
}

// Helper to add edges to Adjacency List
void addEdge(struct Node* adj[], int u, int v) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->dest = v;
    newNode->next = adj[u];
    adj[u] = newNode;
}

int main() {
    int n, m, s;
    if (scanf("%d %d", &n, &m) != 2) return 0;

    struct Node** adj = (struct Node**)malloc(n * sizeof(struct Node*));
    for (int i = 0; i < n; i++) adj[i] = NULL;

    for (int i = 0; i < m; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        // Assuming undirected graph for this example
        addEdge(adj, u, v);
        addEdge(adj, v, u);
    }

    scanf("%d", &s); // Starting vertex

    // Initialize visited array
    visited = (int*)calloc(n, sizeof(int));

    printf("DFS Traversal: ");
    DFS(adj, s);
    printf("\n");

    return 0;
}
