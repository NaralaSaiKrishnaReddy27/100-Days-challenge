#include <stdio.h>

// Recursive function to find the n-th Fibonacci number
int fib(int n) {
    // Base Case: fib(0) = 0
    if (n == 0) {
        return 0;
    }
    // Base Case: fib(1) = 1
    if (n == 1) {
        return 1;
    }
    // Recursive Step
    return fib(n - 1) + fib(n - 2);
}

int main() {
    int n;

    // Read the input integer n
    if (scanf("%d", &n) != 1) return 0;

    // Call the recursive function and print the result
    printf("%d\n", fib(n));

    return 0;
}
