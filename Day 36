#include <stdio.h>
#include <stdlib.h>

struct Node {
    int data;
    struct Node* next;
};

struct CircularQueue {
    struct Node *front, *rear;
};

// Function to enqueue an element
void enqueue(struct CircularQueue* q, int value) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;
    
    if (q->front == NULL) {
        q->front = newNode;
    } else {
        q->rear->next = newNode;
    }
    
    q->rear = newNode;
    q->rear->next = q->front; // Make it circular
}

// Function to dequeue an element
void dequeue(struct CircularQueue* q) {
    if (q->front == NULL) return;

    if (q->front == q->rear) {
        free(q->front);
        q->front = q->rear = NULL;
    } else {
        struct Node* temp = q->front;
        q->front = q->front->next;
        q->rear->next = q->front; // Maintain circularity
        free(temp);
    }
}

int main() {
    int n, m, val;
    struct CircularQueue* q = (struct CircularQueue*)malloc(sizeof(struct CircularQueue));
    q->front = q->rear = NULL;

    // Input: number of enqueues
    if (scanf("%d", &n) != 1) return 0;
    for (int i = 0; i < n; i++) {
        scanf("%d", &val);
        enqueue(q, val);
    }

    // Input: number of dequeues
    if (scanf("%d", &m) != 1) m = 0;
    for (int i = 0; i < m; i++) {
        dequeue(q);
    }

    // Output: Traverse and print
    if (q->front != NULL) {
        struct Node* temp = q->front;
        do {
            printf("%d%s", temp->data, (temp->next == q->front) ? "" : " ");
            temp = temp->next;
        } while (temp != q->front);
        printf("\n");
    }

    return 0;
}
