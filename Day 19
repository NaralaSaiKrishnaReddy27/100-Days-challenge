#include <stdio.h>
#include <stdlib.h>
#include <math.h>

// Comparison function for qsort
int compare(const void *a, const void *b) {
    return (*(int*)a - *(int*)b);
}

int main() {
    int n;
    if (scanf("%d", &n) != 1 || n < 2) return 0;

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Step 1: Sort the array
    qsort(arr, n, sizeof(int), compare);

    int left = 0;
    int right = n - 1;
    int min_sum = arr[left] + arr[right];
    int res_l = left, res_r = right;

    // Step 2: Two-pointer search
    while (left < right) {
        int sum = arr[left] + arr[right];

        // Check if the current absolute sum is closer to zero
        if (abs(sum) < abs(min_sum)) {
            min_sum = sum;
            res_l = left;
            res_r = right;
        }

        // If sum is 0, we found the closest possible sum
        if (sum == 0) break;

        // If sum is negative, move left pointer to increase sum
        if (sum < 0) {
            left++;
        } 
        // If sum is positive, move right pointer to decrease sum
        else {
            right--;
        }
    }

    // Step 3: Output the pair
    // (Note: To match example output order, print the smaller value first)
    printf("%d %d\n", arr[res_l], arr[res_r]);

    return 0;
}
