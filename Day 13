#include <stdio.h>

int main() {
    int r, c;

    // Read dimensions
    if (scanf("%d %d", &r, &c) != 2) return 0;

    int mat[r][c];

    // Read matrix elements
    for (int i = 0; i < r; i++) {
        for (int j = 0; j < c; j++) {
            scanf("%d", &mat[i][j]);
        }
    }

    int top = 0, bottom = r - 1;
    int left = 0, right = c - 1;
    int first = 1; // Helper for formatting output spaces

    while (top <= bottom && left <= right) {
        // 1. Move Left to Right across the top row
        for (int i = left; i <= right; i++) {
            printf("%s%d", first ? "" : " ", mat[top][i]);
            first = 0;
        }
        top++;

        // 2. Move Top to Bottom down the right column
        for (int i = top; i <= bottom; i++) {
            printf(" %d", mat[i][right]);
        }
        right--;

        // 3. Move Right to Left across the bottom row (if rows remain)
        if (top <= bottom) {
            for (int i = right; i >= left; i--) {
                printf(" %d", mat[bottom][i]);
            }
            bottom--;
        }

        // 4. Move Bottom to Top up the left column (if columns remain)
        if (left <= right) {
            for (int i = bottom; i >= top; i--) {
                printf(" %d", mat[i][left]);
            }
            left++;
        }
    }
    printf("\n");

    return 0;
}
