#include <stdio.h>
#include <stdlib.h>

// Binary Tree Node Structure
struct Node {
    int data;
    struct Node *left, *right;
};

// Helper function to create a new node
struct Node* newNode(int val) {
    if (val == -1) return NULL;
    struct Node* node = (struct Node*)malloc(sizeof(struct Node));
    node->data = val;
    node->left = node->right = NULL;
    return node;
}

// Function to find the height of the tree
int findHeight(struct Node* root) {
    if (root == NULL) {
        return 0;
    }

    int leftH = findHeight(root->left);
    int rightH = findHeight(root->right);

    // Return the maximum of the two heights plus 1 for current node
    return (leftH > rightH ? leftH : rightH) + 1;
}

int main() {
    int n;
    // Input number of nodes (including -1 for NULL)
    if (scanf("%d", &n) != 1 || n <= 0) return 0;

    int *arr = (int*)malloc(n * sizeof(int));
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Standard Level-Order Construction
    struct Node** queue = (struct Node**)malloc(n * sizeof(struct Node*));
    int front = 0, rear = 0;

    struct Node* root = newNode(arr[0]);
    if (root) queue[rear++] = root;

    int i = 1;
    while (i < n && front < rear) {
        struct Node* parent = queue[front++];

        // Process Left Child
        if (i < n) {
            parent->left = newNode(arr[i++]);
            if (parent->left) queue[rear++] = parent->left;
        }

        // Process Right Child
        if (i < n) {
            parent->right = newNode(arr[i++]);
            if (parent->right) queue[rear++] = parent->right;
        }
    }

    // Output the result
    printf("%d\n", findHeight(root));

    // Cleanup
    free(arr);
    free(queue);
    return 0;
}
