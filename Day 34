#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>
#include <string.h>

// Define Node for the Stack
struct Node {
    int data;
    struct Node* next;
};

// Push operation
void push(struct Node** top, int value) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = value;
    newNode->next = *top;
    *top = newNode;
}

// Pop operation
int pop(struct Node** top) {
    if (*top == NULL) return 0;
    struct Node* temp = *top;
    int val = temp->data;
    *top = (*top)->next;
    free(temp);
    return val;
}

int main() {
    char exp[100];
    struct Node* stack = NULL;

    // Use scanf with %[^\n] to read the entire line including spaces
    if (scanf("%[^\n]", exp) != 1) return 0;

    char* token = strtok(exp, " ");

    while (token != NULL) {
        // If token is a number (handles multi-digit and negative)
        if (isdigit(token[0]) || (token[0] == '-' && isdigit(token[1]))) {
            push(&stack, atoi(token));
        } 
        // If token is an operator
        else {
            int op2 = pop(&stack); // Second operand is popped first
            int op1 = pop(&stack); // First operand is popped second

            switch (token[0]) {
                case '+': push(&stack, op1 + op2); break;
                case '-': push(&stack, op1 - op2); break;
                case '*': push(&stack, op1 * op2); break;
                case '/': push(&stack, op1 / op2); break;
            }
        }
        token = strtok(NULL, " ");
    }

    printf("%d\n", pop(&stack));

    return 0;
}
