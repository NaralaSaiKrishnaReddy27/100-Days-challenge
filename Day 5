#include <stdio.h>

int main() {
    int p, q;

    // Read size and elements of the first server log
    if (scanf("%d", &p) != 1) return 0;
    int log1[p];
    for (int i = 0; i < p; i++) scanf("%d", &log1[i]);

    // Read size and elements of the second server log
    if (scanf("%d", &q) != 1) return 0;
    int log2[q];
    for (int i = 0; i < q; i++) scanf("%d", &log2[i]);

    // Resultant log size is p + q
    int merged[p + q];
    int i = 0; // Pointer for log1
    int j = 0; // Pointer for log2
    int k = 0; // Pointer for merged log

    // Compare elements from both logs and pick the smaller one
    while (i < p && j < q) {
        if (log1[i] <= log2[j]) {
            merged[k++] = log1[i++];
        } else {
            merged[k++] = log2[j++];
        }
    }

    // If there are remaining elements in log1, add them
    while (i < p) {
        merged[k++] = log1[i++];
    }

    // If there are remaining elements in log2, add them
    while (j < q) {
        merged[k++] = log2[j++];
    }

    // Print the merged chronological log
    for (int m = 0; m < k; m++) {
        printf("%d%s", merged[m], (m == k - 1) ? "" : " ");
    }
    printf("\n");

    return 0;
}
