#include <stdio.h>
#include <stdlib.h>
#include <limits.h>

#define INF INT_MAX

struct Edge {
    int dest, weight;
    struct Edge* next;
};

typedef struct {
    int v, dist;
} HeapNode;

// Simple Min-Heap Implementation
typedef struct {
    HeapNode* data;
    int size;
} MinHeap;

void swap(HeapNode* a, HeapNode* b) {
    HeapNode temp = *a;
    *a = *b;
    *b = temp;
}

void heapify(MinHeap* hp, int i) {
    int smallest = i;
    int left = 2 * i + 1;
    int right = 2 * i + 2;
    if (left < hp->size && hp->data[left].dist < hp->data[smallest].dist) smallest = left;
    if (right < hp->size && hp->data[right].dist < hp->data[smallest].dist) smallest = right;
    if (smallest != i) {
        swap(&hp->data[i], &hp->data[smallest]);
        heapify(hp, smallest);
    }
}

void push(MinHeap* hp, int v, int dist) {
    int i = hp->size++;
    hp->data[i].v = v;
    hp->data[i].dist = dist;
    while (i != 0 && hp->data[(i - 1) / 2].dist > hp->data[i].dist) {
        swap(&hp->data[i], &hp->data[(i - 1) / 2]);
        i = (i - 1) / 2;
    }
}

HeapNode pop(MinHeap* hp) {
    HeapNode root = hp->data[0];
    hp->data[0] = hp->data[--hp->size];
    heapify(hp, 0);
    return root;
}

// Main Dijkstra Function
void dijkstra(struct Edge* adj[], int n, int src) {
    int* dist = (int*)malloc(n * sizeof(int));
    for (int i = 0; i < n; i++) dist[i] = INF;

    MinHeap hp;
    hp.data = (HeapNode*)malloc(n * n * sizeof(HeapNode)); // Max possible updates
    hp.size = 0;

    dist[src] = 0;
    push(&hp, src, 0);

    while (hp.size > 0) {
        HeapNode top = pop(&hp);
        int u = top.v;
        int d = top.dist;

        if (d > dist[u]) continue; // Optimization: skip outdated distances

        struct Edge* edge = adj[u];
        while (edge != NULL) {
            if (dist[u] != INF && dist[u] + edge->weight < dist[edge->dest]) {
                dist[edge->dest] = dist[u] + edge->weight;
                push(&hp, edge->dest, dist[edge->dest]);
            }
            edge = edge->next;
        }
    }

    printf("Vertex \t Distance from Source %d\n", src);
    for (int i = 0; i < n; i++) {
        if (dist[i] == INF) printf("%d \t INF\n", i);
        else printf("%d \t %d\n", i, dist[i]);
    }
}

void addEdge(struct Edge* adj[], int u, int v, int w) {
    struct Edge* newNode = (struct Edge*)malloc(sizeof(struct Edge));
    newNode->dest = v;
    newNode->weight = w;
    newNode->next = adj[u];
    adj[u] = newNode;
}

int main() {
    int n, m, src;
    scanf("%d %d", &n, &m);
    struct Edge** adj = (struct Edge**)calloc(n, sizeof(struct Edge*));

    for (int i = 0; i < m; i++) {
        int u, v, w;
        scanf("%d %d %d", &u, &v, &w);
        addEdge(adj, u, v, w);
        addEdge(adj, v, u, w); // Undirected
    }
    scanf("%d", &src);

    dijkstra(adj, n, src);
    return 0;
}
