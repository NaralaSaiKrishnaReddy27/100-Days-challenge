#include <stdio.h>

int main() {
    int n;

    // Read the size of the array
    if (scanf("%d", &n) != 1) return 0;
    
    // Handle empty array case
    if (n == 0) return 0;

    int arr[n];

    // Read n elements
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Index 'j' will track the position of the last unique element found
    int j = 0;

    // Iterate through the array starting from the second element
    for (int i = 1; i < n; i++) {
        // If the current element is different from the last unique element
        if (arr[i] != arr[j]) {
            j++;             // Move the unique pointer forward
            arr[j] = arr[i]; // Update the position with the new unique value
        }
    }

    // The number of unique elements is (j + 1)
    for (int k = 0; k <= j; k++) {
        printf("%d%s", arr[k], (k == j) ? "" : " ");
    }
    printf("\n");

    return 0;
}
